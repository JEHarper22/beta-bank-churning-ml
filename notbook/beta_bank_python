import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import (
    f1_score,
    roc_auc_score,
    roc_curve,
    confusion_matrix,
    ConfusionMatrixDisplay
)
from sklearn.linear_model import LogisticRegression
from sklearn.ensemble import RandomForestClassifier
from sklearn.utils import shuffle

# Load data
df = pd.read_csv('/datasets/Churn.csv')

# Review data
print(df.head())
print(df.info())
print(df.isna().sum())
print(df.describe())

# Drop unnecessary columns
df = df.drop(['RowNumber', 'CustomerId', 'Surname'], axis=1)

# Check target balance
print(df['Exited'].value_counts())
print()
print(df['Exited'].value_counts(normalize=True))

# Plot class distribution
df['Exited'].value_counts().plot(kind='bar')
plt.title('Class Distribution')
plt.xlabel('Exited')
plt.ylabel('Count')
plt.xticks(rotation=0)
plt.show()

# One-hot encoding
df_ohe = pd.get_dummies(df, drop_first=True)
print(df_ohe.head())

# Replace inf values and fill missing values
df_ohe = df_ohe.replace([np.inf, -np.inf], np.nan)
df_ohe = df_ohe.fillna(0)

# Define features and target
target = df_ohe['Exited']
features = df_ohe.drop('Exited', axis=1)

# Split data
features_train, features_temp, target_train, target_temp = train_test_split(
    features, target, test_size=0.4, random_state=12345, stratify=target
)

features_valid, features_test, target_valid, target_test = train_test_split(
    features_temp, target_temp, test_size=0.5, random_state=12345, stratify=target_temp
)

print('Train:', features_train.shape)
print('Valid:', features_valid.shape)
print('Test:', features_test.shape)

# Scale numeric columns
numeric = ['CreditScore', 'Age', 'Tenure', 'Balance', 'NumOfProducts', 'EstimatedSalary']

scaler = StandardScaler()
scaler.fit(features_train[numeric])

features_train_scaled = features_train.copy()
features_valid_scaled = features_valid.copy()
features_test_scaled = features_test.copy()

features_train_scaled[numeric] = scaler.transform(features_train[numeric])
features_valid_scaled[numeric] = scaler.transform(features_valid[numeric])
features_test_scaled[numeric] = scaler.transform(features_test[numeric])

print(features_train_scaled.isna().sum())
print(features_valid_scaled.isna().sum())
print(features_test_scaled.isna().sum())

# Baseline Logistic Regression
model_lr = LogisticRegression(random_state=12345, max_iter=1000)
model_lr.fit(features_train_scaled, target_train)

pred_valid_lr = model_lr.predict(features_valid_scaled)
prob_valid_lr = model_lr.predict_proba(features_valid_scaled)[:, 1]

print('Baseline Logistic Regression')
print('F1:', f1_score(target_valid, pred_valid_lr))
print('AUC-ROC:', roc_auc_score(target_valid, prob_valid_lr))

cm = confusion_matrix(target_valid, pred_valid_lr)
disp = ConfusionMatrixDisplay(confusion_matrix=cm)
disp.plot()
plt.title('Baseline Logistic Regression')
plt.show()

# Balanced Logistic Regression
model_lr_balanced = LogisticRegression(
    random_state=12345,
    max_iter=1000,
    class_weight='balanced'
)

model_lr_balanced.fit(features_train_scaled, target_train)

pred_valid_lr_bal = model_lr_balanced.predict(features_valid_scaled)
prob_valid_lr_bal = model_lr_balanced.predict_proba(features_valid_scaled)[:, 1]

print('Logistic Regression with class_weight=balanced')
print('F1:', f1_score(target_valid, pred_valid_lr_bal))
print('AUC-ROC:', roc_auc_score(target_valid, prob_valid_lr_bal))

# Upsampling function
def upsample(features, target, repeat):
    features_zeros = features[target == 0]
    features_ones = features[target == 1]
    target_zeros = target[target == 0]
    target_ones = target[target == 1]

    features_upsampled = pd.concat([features_zeros] + [features_ones] * repeat)
    target_upsampled = pd.concat([target_zeros] + [target_ones] * repeat)

    features_upsampled, target_upsampled = shuffle(
        features_upsampled, target_upsampled, random_state=12345
    )

    return features_upsampled, target_upsampled

repeat = int(target_train[target_train == 0].count() / target_train[target_train == 1].count())

features_train_up, target_train_up = upsample(features_train_scaled, target_train, repeat)

print(target_train.value_counts())
print()
print(target_train_up.value_counts())

# Logistic Regression with Upsampling
model_lr_up = LogisticRegression(random_state=12345, max_iter=1000)
model_lr_up.fit(features_train_up, target_train_up)

pred_valid_lr_up = model_lr_up.predict(features_valid_scaled)
prob_valid_lr_up = model_lr_up.predict_proba(features_valid_scaled)[:, 1]

print('Logistic Regression with Upsampling')
print('F1:', f1_score(target_valid, pred_valid_lr_up))
print('AUC-ROC:', roc_auc_score(target_valid, prob_valid_lr_up))

# Random Forest tuning
best_model = None
best_result = 0
best_depth = 0
best_est = 0
best_auc = 0

for depth in range(2, 11):
    for est in [50, 100, 150]:
        model_rf = RandomForestClassifier(
            random_state=12345,
            n_estimators=est,
            max_depth=depth,
            class_weight='balanced'
        )

        model_rf.fit(features_train, target_train)
        pred_valid_rf = model_rf.predict(features_valid)
        prob_valid_rf = model_rf.predict_proba(features_valid)[:, 1]

        f1 = f1_score(target_valid, pred_valid_rf)
        auc = roc_auc_score(target_valid, prob_valid_rf)

        if f1 > best_result:
            best_model = model_rf
            best_result = f1
            best_depth = depth
            best_est = est
            best_auc = auc

print('Best Random Forest')
print('Depth:', best_depth)
print('Estimators:', best_est)
print('F1:', best_result)
print('AUC-ROC:', best_auc)

# Compare models
results = pd.DataFrame({
    'Model': [
        'Baseline Logistic Regression',
        'Balanced Logistic Regression',
        'Upsampled Logistic Regression',
        'Random Forest'
    ],
    'F1': [
        f1_score(target_valid, pred_valid_lr),
        f1_score(target_valid, pred_valid_lr_bal),
        f1_score(target_valid, pred_valid_lr_up),
        best_result
    ],
    'AUC_ROC': [
        roc_auc_score(target_valid, prob_valid_lr),
        roc_auc_score(target_valid, prob_valid_lr_bal),
        roc_auc_score(target_valid, prob_valid_lr_up),
        best_auc
    ]
})

print(results)

plt.figure(figsize=(8, 5))
plt.bar(results['Model'], results['F1'])
plt.title('Validation F1 Score by Model')
plt.ylabel('F1 Score')
plt.xticks(rotation=25, ha='right')
plt.show()

# Final test evaluation
pred_test = best_model.predict(features_test)
prob_test = best_model.predict_proba(features_test)[:, 1]

print('Final Test Results')
print('F1:', f1_score(target_test, pred_test))
print('AUC-ROC:', roc_auc_score(target_test, prob_test))

# ROC Curve
fpr, tpr, thresholds = roc_curve(target_test, prob_test)

plt.figure(figsize=(7, 5))
plt.plot(fpr, tpr, label='ROC Curve')
plt.plot([0, 1], [0, 1], linestyle='--')
plt.xlabel('False Positive Rate')
plt.ylabel('True Positive Rate')
plt.title('ROC Curve - Final Model')
plt.legend()
plt.show()

# Final confusion matrix
cm_test = confusion_matrix(target_test, pred_test)
disp = ConfusionMatrixDisplay(confusion_matrix=cm_test)
disp.plot()
plt.title('Final Model Confusion Matrix')
plt.show()
